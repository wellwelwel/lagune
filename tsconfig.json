{
  "include": ["src", "scripts", "test", ".claude/skills"],
  "exclude": ["src/dashboard/client"],
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noImplicitAny": true,
    "allowJs": false,
    "allowUnusedLabels": false,
    "alwaysStrict": true,
    "noEmitOnError": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true
  }
}
